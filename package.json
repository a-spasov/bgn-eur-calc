{
  "name": "bg-euro",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
 "scripts": {
    "dev:css": "npx @tailwindcss/cli -i ./src/input.css -o ./dist/styles.css --watch",
    "dev:js": "esbuild src/scripts/main.js --bundle --outfile=dist/scripts.js --watch",
    "dev": "concurrently \"npm run dev:css\" \"npm run dev:js\"",

    "build:css": "npx @tailwindcss/cli -i ./src/input.css -o ./dist/styles.css --minify",
    "build:js": "esbuild src/scripts/main.js --bundle --minify --outfile=dist/scripts.js",
    "build": "npm run build:css && npm run build:js"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.1.17",
    "tailwindcss": "^4.1.17"
  },
  "devDependencies": {
    "esbuild": "0.27.0"
  }
}
